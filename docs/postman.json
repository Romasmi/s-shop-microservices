					{
						"key": "Content-Type",
						"value": "application/json"
					}
				],
				"body": {
					"mode": "raw",
					"raw": "{\n  \"firstName\": \"Hacker\"\n}"
				},
				"url": {
					"raw": "{{baseUrl}}/user/{{user1_id}}",
					"host": [
						"{{baseUrl}}"
					],
					"path": [
						"user",
						"{{user1_id}}"
					]
				}
			}
		},
		{
			"name": "4. Login User 1",
			"event": [
				{
					"listen": "test",
					"script": {
						"exec": [
							"const response = pm.response.json();",
							"pm.collectionVariables.set(\"user1_token\", response.token);",
							"console.log(\"User 1 logged in, token received\");",
							"pm.test(\"Status code is 200\", function () { pm.response.to.have.status(200); });"
