					"script": {
						"exec": [
							"const response = pm.response.json();",
							"pm.test(\"First Name is updated\", function () { pm.expect(response.firstName).to.eql(\"NewName1\"); });",
							"console.log(\"Verified User 1 First Name: \" + response.firstName);",
							"pm.test(\"Status code is 200\", function () { pm.response.to.have.status(200); });"
