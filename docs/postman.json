	"item": [
		{
			"name": "1. Register User 1",
			"event": [
				{
					"listen": "test",
					"script": {
						"exec": [
							"const response = pm.response.json();",
							"pm.collectionVariables.set(\"user1_id\", response.id);",
							"pm.collectionVariables.set(\"user1_username\", response.username);",
							"pm.collectionVariables.set(\"user1_password\", response.password);",
							"console.log(\"User 1 registered: \" + response.username + \" ID: \" + response.id);",
							"pm.test(\"Status code is 200\", function () { pm.response.to.have.status(200); });"
						],
						"type": "text/javascript"
					}
				}
			],
			"request": {
				"method": "POST",
				"header": [
					{
						"key": "Content-Type",
						"value": "application/json"
					}
				],
				"body": {
					"mode": "raw",
					"raw": "{\n  \"username\": \"user1_{{$randomUserName}}\",\n  \"firstName\": \"{{$randomFirstName}}\",\n  \"lastName\": \"{{$randomLastName}}\",\n  \"email\": \"{{$randomEmail}}\",\n  \"phone\": \"{{$randomPhoneNumber}}\"\n}"
				},
				"url": {
					"raw": "{{baseUrl}}/user",
					"host": [
						"{{baseUrl}}"
					],
					"path": [
						"user"
					]
				}
			}
		},
		{
			"name": "2. Check Get User 1 (Unauthorized)",
			"event": [
				{
					"listen": "test",
					"script": {
						"exec": [
							"pm.test(\"Status code is 401\", function () { pm.response.to.have.status(401); });",
							"console.log(\"Unauthorized GET request status: \" + pm.response.code);"
						],
						"type": "text/javascript"
					}
				}
			],
			"request": {
				"method": "GET",
				"header": [],
				"url": {
					"raw": "{{baseUrl}}/user/{{user1_id}}",
					"host": [
						"{{baseUrl}}"
					],
					"path": [
						"user",
						"{{user1_id}}"
					]
				}
			}
		},
		{
			"name": "3. Check Update User 1 (Unauthorized)",
